        {
          "type": "quote",
          "text": "Author in the app. Read in the file.",
          "cite": "iDoc workflow"
        },
        {
          "type": "button",
          "label": "Toggle theme",
          "action": "toggle-theme"
        },
        {
          "type": "button",
          "label": "Go to page 3",
          "action": "goto-questions"
        },
        {
          "type": "link",
          "label": "Open the project repository",
          "action": "open-repo"
        }
      ]
    },
    {
      "id": "page-3",
      "title": "Questions and Export",
      "elements": [
        {
          "type": "heading",
          "level": 2,
          "text": "Quiz, reveal, and export"
        },
        {
          "type": "paragraph",
          "text": "The runtime still supports questions, answer reveal, save state, and JSON export. Search terms like export, runtime, Flutter, and image should match here."
        },
        {
          "type": "question",
          "id": "question-engine",
          "questionType": "mcq",
          "prompt": "Where should users author new iDoc documents now?",
          "options": [
            "Directly inside the exported HTML runtime.",
            "Inside the Flutter Windows authoring app.",
            "In a hidden backend service."
          ],
          "answer": 1,
          "explanation": "The Flutter editor is now the source of truth. The HTML file is the generated runtime output."
        },
        {
          "type": "button",
          "label": "Reveal answer",
          "action": "show-q1-answer"
        },
        {
          "type": "button",
          "label": "Save reader state",
          "action": "save-doc"
        },
        {
          "type": "button",
          "label": "Export current JSON",
          "variant": "primary",
          "action": "export-json"
        },
        {
          "type": "callout",
          "tone": "success",
          "title": "Shareable output",
          "text": "You can send the exported .idoc.html file to someone else and they can open it directly in the browser."
        }
      ]
