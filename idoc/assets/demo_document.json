  "pages": [
    {
      "id": "page-1",
      "title": "Welcome",
      "elements": [
        {
          "type": "heading",
          "level": 1,
          "text": "Welcome to iDoc"
        },
        {
          "type": "paragraph",
          "text": "iDoc Studio now authors documents on Windows and exports a standalone reader. Inline math like $\\int_0^1 x^2 \\, dx = \\frac{1}{3}$ can live directly inside normal text blocks."
        },
        {
          "type": "callout",
          "tone": "info",
          "title": "Recommended workflow",
          "text": "Create or edit content in iDoc Studio, keep advanced fixes available through raw JSON, then export a fresh .idoc.html file for sharing."
        },
        {
          "type": "button",
          "label": "Open overview popup",
          "variant": "primary",
          "action": "open-intro-popup"
        },
        {
          "type": "paragraph",
          "text": "Search terms such as runtime, export, Flutter, image, and popup appear across this demo so the browser reader search has useful matches."
        },
        {
          "type": "text",
          "text": "Recommended save name for the standalone file: example.idoc.html"
        }
      ]
    },
    {
      "id": "page-2",
      "title": "Images and Runtime",
      "elements": [
        {
          "type": "heading",
          "level": 2,
          "text": "Images stay embedded in the export"
        },
        {
          "type": "paragraph",
          "text": "Clipboard image paste creates canonical image blocks. The exported .idoc.html keeps those images self-contained, so the file can move without breaking links."
        },
        {
