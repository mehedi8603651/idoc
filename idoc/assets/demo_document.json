        {
          "type": "paragraph",
          "text": "This paragraph sits after the image to demonstrate runtime layout, spacing, and proportional image sizing in the exported reader."
        },
        {
          "type": "code",
          "language": "js",
          "code": "function exportDocument() {\\n  const blob = new Blob([json], { type: 'application/json' });\\n  download(blob, 'demo.json');\\n}"
